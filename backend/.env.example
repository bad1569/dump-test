# ============================================
# BLINC Chatbot API - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# ============================================

# ============================================
# NODE ENVIRONMENT
# ============================================
# Just copy this:
NODE_ENV=development

# ============================================
# SERVER CONFIGURATION
# ============================================
# Just copy this:
PORT=3000

# ============================================
# MONGODB ATLAS CONNECTION
# ============================================
# Format: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/database_name
# Replace username, password, cluster, and database_name with your actual values (provided by Brenzer/MongoDB holder)
MONGODB_URI=mongodb+srv://your_username:your_password@yourcluster.xxxxx.mongodb.net/blinc_chatbot

# ============================================
# GOOGLE AI (GEMINI)
# ============================================
# Paste the provided API:
GOOGLE_API_KEY=your_google_api_key_here

# ============================================
# ADMIN API KEY (For protected admin routes (NOT NECESSARILY NEEDED, NEEDED ONLY IF YOU WANT TO TEST AND MANUALLY UPLOAD DATA TO DATABASE BY CODE))
# ============================================
# Generate a secure key using CMD, type:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your_generated_admin_key_here


